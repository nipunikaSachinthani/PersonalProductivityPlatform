# EditorConfig — cross-editor consistency
# https://editorconfig.org

root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# — 4-space indent
[*.cs]
indent_style = space
indent_size = 4

# JavaScript / TypeScript — 2-space indent
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# JSON — 2-space indent
[*.json]
indent_style = space
indent_size = 2

# YAML — 2-space indent
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# XML / MSBuild / csproj — 2-space indent
[*.{xml,csproj,props,targets}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
